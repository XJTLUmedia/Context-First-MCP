{
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/mcp",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Accept, Mcp-Session-Id, MCP-Protocol-Version, Last-Event-ID" }
      ]
    }
  ]
}
